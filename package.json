{
  "name": "mini-chess-5x7",
  "version": "0.4.0",
  "description": "A compact browser-based chess variant powered by a small Node.js game engine.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build:docs": "npm run build:docs:readme",
    "build:docs:board": "node scripts/build-docs-board.js",
    "build:docs:readme": "node scripts/build-docs-index.js",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run lint && npm test && npm run format:check"
  },
  "homepage": "https://expertos-tech.github.io/mini-chess-5x7/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/expertos-tech/mini-chess-5x7.git"
  },
  "bugs": {
    "url": "https://github.com/expertos-tech/mini-chess-5x7/issues"
  },
  "keywords": [
    "mini-chess",
    "chess",
    "chess-variant",
    "browser-game",
    "nodejs",
    "websocket",
    "vue"
  ],
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "marked": "^16.0.0",
    "prettier": "^3.0.0"
  }
}
